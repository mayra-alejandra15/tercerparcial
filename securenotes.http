@baseUrl = http://localhost:3000
@accessA = pega_aqui_access_token_usuario_A
@accessB = pega_aqui_access_token_usuario_B
@noteA = pega_aqui_id_nota_usuario_A

### 1. Registrar usuario A
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "usuarioa@test.com",
  "password": "mipassword123"
}

### 2. Login usuario A
# REST Client/Postman guarda la cookie refresh_token automáticamente.
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "usuarioa@test.com",
  "password": "mipassword123"
}

### 3. Ver usuario autenticado A
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessA}}

### 4. Intentar listar notas sin access token -> debe dar 401
GET {{baseUrl}}/notes

### 5. Crear nota de usuario A
POST {{baseUrl}}/notes
Authorization: Bearer {{accessA}}
Content-Type: application/json

{
  "title": "Nota privada A",
  "content": "Contenido privado del usuario A"
}

### 6. Listar notas propias de usuario A
GET {{baseUrl}}/notes
Authorization: Bearer {{accessA}}

### 7. Registrar usuario B
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "usuariob@test.com",
  "password": "mipassword123"
}

### 8. Login usuario B
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "usuariob@test.com",
  "password": "mipassword123"
}

### 9. Usuario B intenta ver nota de A -> debe dar 404
GET {{baseUrl}}/notes/{{noteA}}
Authorization: Bearer {{accessB}}

### 10. Usuario B intenta modificar nota de A -> debe dar 404
PATCH {{baseUrl}}/notes/{{noteA}}
Authorization: Bearer {{accessB}}
Content-Type: application/json

{
  "title": "Intento de ataque IDOR"
}

### 11. Renovar access token con refresh cookie
POST {{baseUrl}}/auth/refresh

### 12. Listar sesiones activas
GET {{baseUrl}}/auth/sessions
Authorization: Bearer {{accessA}}

### 13. Logout sesión actual
POST {{baseUrl}}/auth/logout

### 14. Refresh después de logout -> debe fallar 401
POST {{baseUrl}}/auth/refresh
